generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Quiz {
  id        String     @id @default(cuid())
  title     String
  questions Question[]
}

model Question {
  id             String @id @default(cuid())
  text           String
  type           String
  options        Json?
  correctAnswers Json?

  quizId String
  quiz   Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}
